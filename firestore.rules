rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-0_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- COLLECTION RULES ---

    // 1. Users Collection
    match /users/{userId} {
      allow read: if true; // Allow reading and listing users
      allow write: if true; // Allow creating and updating users
    }

    // 2. Haircuts (Services Catalogue)
    match /haircuts/{haircutId} {
      allow read: if true; // Public catalog of services
      allow write: if true; // In development/demo, allow seeding/updates
    }

    // 3. Barbers (Professionals)
    match /barbers/{barberId} {
      allow read: if true; // Public list of barbers
      allow write: if true; // In development/demo, allow managing team
    }

    // 4. Bookings
    match /bookings/{bookingId} {
      allow read: if true; // Let app query and list bookings for dashboard display
      allow create, update, delete: if true; // Permit scheduling bookings
    }
  }
}
